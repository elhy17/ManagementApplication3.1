<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DidiApp.ViewModels"
             x:Class="DidiApp.Views.FocusView"
             x:DataType="vm:FocusViewModel">
  <Border Classes="card" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="60">
    <StackPanel Spacing="30" HorizontalAlignment="Center">
      <TextBlock Text="{DynamicResource DeepWorkTimer}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
      
      <StackPanel Spacing="10">
        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Width="300" HorizontalAlignment="Center" PlaceholderText="1. Select Category"/>
        
        <ComboBox ItemsSource="{Binding AvailableTasks}" SelectedItem="{Binding SelectedTask}" Width="300" HorizontalAlignment="Center" PlaceholderText="2. Select Task">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Title}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
        <TextBlock Text="Target Minutes:" VerticalAlignment="Center" Classes="muted"/>
        <TextBox Text="{Binding TargetFocusMinutes}" Width="60" TextAlignment="Center"/>
      </StackPanel>

      <TextBlock Text="{Binding TimeDisplay}" FontSize="80" FontWeight="Bold" HorizontalAlignment="Center"/>
      
      <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
        <Button Classes="pink" Content="{DynamicResource StartBtn}" Command="{Binding StartCommand}" Width="100" HorizontalContentAlignment="Center"/>
        <Button Classes="soft" Content="{DynamicResource PauseBtn}" Command="{Binding PauseCommand}" Width="100" HorizontalContentAlignment="Center"/>
        <Button Classes="soft" Content="{DynamicResource StopBtn}" Command="{Binding StopCommand}" Width="100" HorizontalContentAlignment="Center"/>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>