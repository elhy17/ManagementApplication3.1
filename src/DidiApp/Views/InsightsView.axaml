<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DidiApp.ViewModels"
             x:Class="DidiApp.Views.InsightsView"
             x:DataType="vm:InsightsViewModel">
  <StackPanel Spacing="20">
    <TextBlock Text="{DynamicResource NavInsights}" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
    
    <Border Classes="card">
      <StackPanel Spacing="15">
        <TextBlock Text="Time Logged by Category" FontSize="18" FontWeight="SemiBold" Classes="muted"/>
        
        <ItemsControl ItemsSource="{Binding CategoryData}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="120,*,80" Margin="0,10">
                <TextBlock Grid.Column="0" Text="{Binding Category}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                
                <ProgressBar Grid.Column="1" Minimum="0" Maximum="{Binding MaxValue}" Value="{Binding TotalMinutes}" Height="20" CornerRadius="10" Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource StrokeBrush}" VerticalAlignment="Center" Margin="10,0"/>
                
                <TextBlock Grid.Column="2" Text="{Binding DisplayText}" VerticalAlignment="Center" HorizontalAlignment="Right" Classes="muted"/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="Add tasks and log focus time to see your data grow!" FontSize="12" Classes="muted" Margin="0,20,0,0" IsVisible="{Binding !CategoryData.Count}"/>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
