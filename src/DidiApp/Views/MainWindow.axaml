<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DidiApp.ViewModels"
        x:Class="DidiApp.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1100" Height="750"
        Title="{DynamicResource AppTitle}" Background="{DynamicResource BgBrush}">
  <Grid ColumnDefinitions="240,*">
    
    <Border Grid.Column="0" Background="{DynamicResource Card2Brush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="0,0,1,0">
      <Grid RowDefinitions="*,Auto" Margin="20,40,20,20">
        
        <StackPanel Grid.Row="0" Spacing="10">
          <TextBlock Text="{DynamicResource AppTitle}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,30"/>
          <Button Classes="soft" Content="{DynamicResource NavTasks}" Command="{Binding NavTasks}" HorizontalAlignment="Stretch"/>
          <Button Classes="soft" Content="{DynamicResource NavFocus}" Command="{Binding NavFocus}" HorizontalAlignment="Stretch"/>
          <Button Classes="soft" Content="{DynamicResource NavInsights}" Command="{Binding NavInsights}" HorizontalAlignment="Stretch"/>
          <Button Classes="soft" Content="{DynamicResource NavJournal}" Command="{Binding NavJournal}" HorizontalAlignment="Stretch"/>
          <Button Classes="soft" Content="{DynamicResource NavGoals}" Command="{Binding NavGoals}" HorizontalAlignment="Stretch"/>
        </StackPanel>

        <Button Grid.Row="1" Classes="soft" Content="{DynamicResource NavSettings}" Command="{Binding NavSettings}" HorizontalAlignment="Stretch"/>
      </Grid>
    </Border>

    <TransitioningContentControl Grid.Column="1" Content="{Binding CurrentPage}" Padding="24" />
    
  </Grid>
</Window>
